      "cell_type": "markdown",
      "source": [
        "#--**K-Means**"
      ],
      "metadata": {
        "id": "JHPKkFX0CzHw"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.cluster import KMeans\n",
        "import numpy as np\n",
        "\n",
        "# Training data\n",
        "X = np.array([\n",
        "    [1.713, 1.586],\n",
        "    [1.713, 1.586],\n",
        "    [0.353, 1.240],\n",
        "    [0.940, 1.286],\n",
        "    [0.940, 1.566],\n",
        "    [1.266, 1.106],\n",
        "    [0.540, 0.419],\n",
        "    [0.459, 1.799],\n",
        "    [0.773, 0.186]\n",
        "])\n",
        "\n",
        "# Class labels\n",
        "y = np.array([0, 1, 1, 0, 1, 0, 1, 1, 1])\n",
        "\n",
        "# Create KMeans model\n",
        "kmeans = KMeans(n_clusters=3, random_state=0)\n",
        "\n",
        "# Fit the model\n",
        "kmeans.fit(X, y)\n",
        "\n",
        "print(\"The input data is\")\n",
        "print(\"VAR1 \\t VAR2 \\t CLASS\")\n",
        "\n",
        "i = 0\n",
        "for val in X:\n",
        "    print(val[0], \"\\t\", val[1], \"\\t\", y[i])\n",
        "    i += 1\n",
        "\n",
        "print(\"=\" * 20)\n",
        "\n",
        "# Get test data from user\n",
        "print(\"The Test data to predict\")\n",
        "test_data = []\n",
        "\n",
        "VAR1 = float(input(\"Enter value for VAR1: \"))\n",
        "VAR2=float(input(\"Enter Value of Var2\"))\n",
        "test_data.append(VAR1)\n",
        "test_data.append(VAR2)\n",
        "print(\"=\"*20)\n",
        "print(\"The predicted class iss:\",kmeans.predict([test_data]))"
      ],
      "metadata": {
        "id": "YpH4ouoEF5ey"
      },
